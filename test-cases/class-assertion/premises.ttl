# InferTest — OWL 2 construct test case
# Construct : ClassAssertion, over a multi-level rdfs:subClassOf hierarchy
# File      : premises.ttl
# Purpose   : Buddy is asserted a member of only the MOST SPECIFIC class in
#             a 4-level hierarchy (Labrador < Dog < Mammal < Animal <
#             LivingThing). A reasoner that merely echoes the direct
#             assertion back would pass a single-level test by accident;
#             this one only passes if it actually walks the full subclass
#             chain and types Buddy as every ancestor class too.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/class-assertion> rdf:type owl:Ontology ;
    rdfs:label "InferTest — class assertion over a multi-level subclass hierarchy" .

#################################################################
#    Classes  (LivingThing > Animal > Mammal > Dog > Labrador)
#################################################################

:ClassAssertion_LivingThing rdf:type owl:Class .

:ClassAssertion_Animal rdf:type owl:Class ;
    rdfs:subClassOf :ClassAssertion_LivingThing .

:ClassAssertion_Mammal rdf:type owl:Class ;
    rdfs:subClassOf :ClassAssertion_Animal .

:ClassAssertion_Dog rdf:type owl:Class ;
    rdfs:subClassOf :ClassAssertion_Mammal .

:ClassAssertion_Labrador rdf:type owl:Class ;
    rdfs:subClassOf :ClassAssertion_Dog .

#################################################################
#    Individuals
#################################################################

### Buddy is only ever asserted a Labrador — every broader type below must
### be inferred by walking the four-level subclass chain.
:ClassAssertion_Buddy rdf:type owl:NamedIndividual , :ClassAssertion_Labrador .
