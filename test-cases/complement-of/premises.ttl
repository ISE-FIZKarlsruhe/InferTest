# InferTest — OWL 2 construct test case
# Construct : owl:complementOf (class negation)
# File      : premises.ttl
# Purpose   : An individual typed as both a class and its complement must
#             make the ontology INCONSISTENT.
#
# See expected-inconsistent.flag instead of expected-entailments.ttl.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/complement-of> rdf:type owl:Ontology ;
    rdfs:label "InferTest — complement of a class (owl:complementOf)" .

#################################################################
#    Classes
#################################################################

:ComplementOf_Human rdf:type owl:Class .

:ComplementOf_NonHuman rdf:type owl:Class ;
    owl:equivalentClass [ rdf:type owl:Class ;
                           owl:complementOf :ComplementOf_Human
                         ] .

#################################################################
#    Individuals
#################################################################

### Violation: Alex cannot be both Human and its complement, NonHuman.
:ComplementOf_Alex rdf:type owl:NamedIndividual ,
        :ComplementOf_Human ,
        :ComplementOf_NonHuman .
