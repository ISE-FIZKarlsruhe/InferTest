# InferTest — OWL 2 construct test case
# Construct : DataPropertyAssertion, over a multi-level rdfs:subPropertyOf
#             hierarchy of datatype properties
# File      : premises.ttl
# Purpose   : Alice's age is asserted through only the MOST SPECIFIC
#             datatype property in a 3-level chain (hasExactAgeInYears <
#             hasAge < hasNumericAttribute < hasAttribute). A reasoner
#             that merely echoes the direct assertion back would pass a
#             single-level test by accident; this one only passes if it
#             actually walks the full subproperty chain and asserts the
#             literal value under every broader datatype property too.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/data-property-assertion> rdf:type owl:Ontology ;
    rdfs:label "InferTest — data property assertion over a multi-level subproperty hierarchy" .

#################################################################
#    Data Properties
#    (hasAttribute > hasNumericAttribute > hasAge > hasExactAgeInYears)
#################################################################

:dataPropertyAssertionHasAttribute rdf:type owl:DatatypeProperty .

:dataPropertyAssertionHasNumericAttribute rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :dataPropertyAssertionHasAttribute .

:dataPropertyAssertionHasAge rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :dataPropertyAssertionHasNumericAttribute .

:dataPropertyAssertionHasExactAgeInYears rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :dataPropertyAssertionHasAge .

#################################################################
#    Individuals
#################################################################

### Alice's age is only ever asserted via the most specific property —
### every broader datatype property below must be inferred by walking the
### three-level subproperty chain.
:DataPropertyAssertion_Alice rdf:type owl:NamedIndividual ;
    :dataPropertyAssertionHasExactAgeInYears "42"^^xsd:integer .
