# InferTest — OWL 2 construct test case
# Construct : DataPropertyAssertion
# File      : premises.ttl
# Purpose   : Baseline sanity check — a plain datatype-property assertion
#             (with a typed literal) must survive being merged into a
#             target ontology and passed through a pipeline unchanged.
#             No inference is required; this catches a broken
#             merge/import/reasoning step early, including literal/
#             datatype mangling.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/data-property-assertion> rdf:type owl:Ontology ;
    rdfs:label "InferTest — data property assertion (DataPropertyAssertion)" .

#################################################################
#    Data Properties
#################################################################

:dataPropertyAssertionHasAge rdf:type owl:DatatypeProperty .

#################################################################
#    Individuals
#################################################################

:DataPropertyAssertion_Alice rdf:type owl:NamedIndividual ;
    :dataPropertyAssertionHasAge "42"^^xsd:integer .
