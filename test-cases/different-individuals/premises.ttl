# InferTest — OWL 2 construct test case
# Construct : owl:differentFrom (individual distinctness)
# File      : premises.ttl
# Purpose   : Declaring the same pair of individuals both owl:sameAs and
#             owl:differentFrom must make the ontology INCONSISTENT.
#
# See expected-inconsistent.flag instead of expected-entailments.ttl.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/different-individuals> rdf:type owl:Ontology ;
    rdfs:label "InferTest — different individuals (owl:differentFrom)" .

#################################################################
#    Individuals
#################################################################

### Violation: A and B cannot be simultaneously asserted identical and
### distinct.
:DifferentIndividuals_A rdf:type owl:NamedIndividual ;
    owl:sameAs :DifferentIndividuals_B ;
    owl:differentFrom :DifferentIndividuals_B .

:DifferentIndividuals_B rdf:type owl:NamedIndividual .
