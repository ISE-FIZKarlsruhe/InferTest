# InferTest — OWL 2 construct test case
# Construct : rdfs:domain
# File      : premises.ttl
# Purpose   : Asserting a property from a subject must type that subject as
#             a member of the property's declared domain class.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/domain> rdf:type owl:Ontology ;
    rdfs:label "InferTest — domain (rdfs:domain)" .

#################################################################
#    Classes
#################################################################

:Domain_Person rdf:type owl:Class .

#################################################################
#    Object Properties
#################################################################

:domainWorksFor rdf:type owl:ObjectProperty ;
    rdfs:domain :Domain_Person .

#################################################################
#    Individuals
#################################################################

### Domain_Employee01 is deliberately left untyped — its Person type must
### come purely from the domain axiom on domainWorksFor.
:Domain_Employee01 rdf:type owl:NamedIndividual ;
    :domainWorksFor :Domain_Acme .

:Domain_Acme rdf:type owl:NamedIndividual .
