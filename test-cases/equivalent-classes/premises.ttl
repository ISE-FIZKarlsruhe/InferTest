# InferTest — OWL 2 construct test case
# Construct : owl:equivalentClass
# File      : premises.ttl
# Purpose   : Membership in one of two equivalent classes must entail
#             membership in the other.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/equivalent-classes> rdf:type owl:Ontology ;
    rdfs:label "InferTest — equivalent classes (owl:equivalentClass)" .

#################################################################
#    Classes
#################################################################

:EquivalentClasses_Human rdf:type owl:Class ;
    owl:equivalentClass :EquivalentClasses_Person .

:EquivalentClasses_Person rdf:type owl:Class .

#################################################################
#    Individuals
#################################################################

:EquivalentClasses_Alex rdf:type owl:NamedIndividual , :EquivalentClasses_Human .
