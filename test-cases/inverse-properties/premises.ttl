# InferTest — OWL 2 construct test case
# Construct : owl:inverseOf
# File      : premises.ttl
# Purpose   : A property assertion must be mirrored through its declared
#             inverse property.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/inverse-properties> rdf:type owl:Ontology ;
    rdfs:label "InferTest — inverse properties (owl:inverseOf)" .

#################################################################
#    Object Properties
#################################################################

:inverseHasParent rdf:type owl:ObjectProperty .

:inverseHasChild rdf:type owl:ObjectProperty ;
    owl:inverseOf :inverseHasParent .

#################################################################
#    Individuals
#################################################################

:InverseProperties_Alice rdf:type owl:NamedIndividual ;
    :inverseHasParent :InverseProperties_Bob .

:InverseProperties_Bob rdf:type owl:NamedIndividual .
