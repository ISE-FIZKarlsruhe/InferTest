# InferTest — OWL 2 construct test case
# Construct : ObjectPropertyAssertion, over a multi-level rdfs:subPropertyOf
#             hierarchy
# File      : premises.ttl
# Purpose   : Alice is related to Bob through only the MOST SPECIFIC object
#             property in a 4-level chain (isBiologicalMotherOf <
#             isMotherOf < isParentOf < isAncestorOf < isRelatedTo). A
#             reasoner that merely echoes the direct assertion back would
#             pass a single-level test by accident; this one only passes
#             if it actually walks the full subproperty chain and asserts
#             the relationship under every broader property too.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/object-property-assertion> rdf:type owl:Ontology ;
    rdfs:label "InferTest — object property assertion over a multi-level subproperty hierarchy" .

#################################################################
#    Object Properties
#    (isRelatedTo > isAncestorOf > isParentOf > isMotherOf > isBiologicalMotherOf)
#################################################################

:objectPropertyAssertionIsRelatedTo rdf:type owl:ObjectProperty .

:objectPropertyAssertionIsAncestorOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :objectPropertyAssertionIsRelatedTo .

:objectPropertyAssertionIsParentOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :objectPropertyAssertionIsAncestorOf .

:objectPropertyAssertionIsMotherOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :objectPropertyAssertionIsParentOf .

:objectPropertyAssertionIsBiologicalMotherOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :objectPropertyAssertionIsMotherOf .

#################################################################
#    Individuals
#################################################################

### Alice is only ever asserted Bob's biological mother — every broader
### relation below must be inferred by walking the four-level subproperty
### chain.
:ObjectPropertyAssertion_Alice rdf:type owl:NamedIndividual ;
    :objectPropertyAssertionIsBiologicalMotherOf :ObjectPropertyAssertion_Bob .

:ObjectPropertyAssertion_Bob rdf:type owl:NamedIndividual .
