# InferTest — OWL 2 construct test case
# Construct : owl:propertyChainAxiom (OWL 2 new construct)
# File      : premises.ttl
# Purpose   : A property chain (hasParent o hasBrother -> hasUncle) must be
#             materialised when both links of the chain are asserted.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/property-chain> rdf:type owl:Ontology ;
    rdfs:label "InferTest — property chain (owl:propertyChainAxiom)" .

#################################################################
#    Object Properties
#################################################################

:propertyChainHasParent rdf:type owl:ObjectProperty .

:propertyChainHasBrother rdf:type owl:ObjectProperty .

:propertyChainHasUncle rdf:type owl:ObjectProperty ;
    owl:propertyChainAxiom ( :propertyChainHasParent :propertyChainHasBrother ) .

#################################################################
#    Individuals
#################################################################

:PropertyChain_Sam rdf:type owl:NamedIndividual ;
    :propertyChainHasParent :PropertyChain_Pat .

:PropertyChain_Pat rdf:type owl:NamedIndividual ;
    :propertyChainHasBrother :PropertyChain_Joe .

:PropertyChain_Joe rdf:type owl:NamedIndividual .
