# InferTest — OWL 2 construct test case
# Construct : rdfs:range
# File      : premises.ttl
# Purpose   : Asserting a property to an object must type that object as a
#             member of the property's declared range class.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/range> rdf:type owl:Ontology ;
    rdfs:label "InferTest — range (rdfs:range)" .

#################################################################
#    Classes
#################################################################

:Range_Organization rdf:type owl:Class .

#################################################################
#    Object Properties
#################################################################

:rangeWorksFor rdf:type owl:ObjectProperty ;
    rdfs:range :Range_Organization .

#################################################################
#    Individuals
#################################################################

:Range_Employee01 rdf:type owl:NamedIndividual ;
    :rangeWorksFor :Range_Employer01 .

### Range_Employer01 is deliberately left untyped — its Organization type
### must come purely from the range axiom on rangeWorksFor.
:Range_Employer01 rdf:type owl:NamedIndividual .
