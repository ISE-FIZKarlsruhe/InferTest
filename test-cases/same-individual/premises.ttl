# InferTest — OWL 2 construct test case
# Construct : owl:sameAs (individual identity)
# File      : premises.ttl
# Purpose   : Property assertions about an individual must propagate to
#             everything declared owl:sameAs it.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/same-individual> rdf:type owl:Ontology ;
    rdfs:label "InferTest — same individual (owl:sameAs)" .

#################################################################
#    Object Properties
#################################################################

:sameIndividualObservedBy rdf:type owl:ObjectProperty .

#################################################################
#    Individuals
#################################################################

:SameIndividual_MorningStar rdf:type owl:NamedIndividual ;
    owl:sameAs :SameIndividual_EveningStar ;
    :sameIndividualObservedBy :SameIndividual_Astronomer .

:SameIndividual_EveningStar rdf:type owl:NamedIndividual .

:SameIndividual_Astronomer rdf:type owl:NamedIndividual .
