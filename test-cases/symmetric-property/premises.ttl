# InferTest — OWL 2 construct test case
# Construct : owl:SymmetricProperty
# File      : premises.ttl
# Purpose   : A symmetric property assertion must hold in both directions.

@prefix : <http://example.org/infertest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.org/infertest> .

<http://example.org/infertest/symmetric-property> rdf:type owl:Ontology ;
    rdfs:label "InferTest — symmetric property (owl:SymmetricProperty)" .

#################################################################
#    Object Properties
#################################################################

:symmetricIsSiblingOf rdf:type owl:ObjectProperty , owl:SymmetricProperty .

#################################################################
#    Individuals
#################################################################

:SymmetricProperty_Alice rdf:type owl:NamedIndividual ;
    :symmetricIsSiblingOf :SymmetricProperty_Bob .

:SymmetricProperty_Bob rdf:type owl:NamedIndividual .
